<Window x:Class="ComputerGames.CatalogMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerGames"
        mc:Ignorable="d"
        Title="CatalogMain" Height="700" Width="1200">
    <Grid Background="#0F172A">

        <Grid.RowDefinitions>
            <RowDefinition Height="190"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <Border Grid.Row="0"
            Background="#1E293B"
            CornerRadius="15"
            Margin="20">

            <StackPanel>

                <TextBlock Text="🎮 Фильтры и сортировка"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="20,15"/>

                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                    <StackPanel Margin="40,0">
                        <TextBlock Text="Платформа"
                               Foreground="White"
                               FontWeight="SemiBold"/>
                        <ComboBox Name="PlatformSort"
                              Width="200"
                              Height="35"
                              SelectionChanged="FilterGames">
                            <ComboBoxItem IsSelected="True" IsEnabled="False">Выберите вариант...</ComboBoxItem>
                            <ComboBoxItem>PC</ComboBoxItem>
                            <ComboBoxItem>Console</ComboBoxItem>
                            <ComboBoxItem>Mobile</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="40,0">
                        <TextBlock Text="Режим"
                               Foreground="White"
                               FontWeight="SemiBold"/>
                        <ComboBox Name="RejimSort"
                              Width="200"
                              Height="35"
                              SelectionChanged="FilterGames">
                            <ComboBoxItem IsSelected="True" IsEnabled="False">Выберите вариант...</ComboBoxItem>
                            <ComboBoxItem>Single</ComboBoxItem>
                            <ComboBoxItem>Online</ComboBoxItem>
                            <ComboBoxItem>Multiplayer</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="40,0">
                        <TextBlock Text="Формат сохранения"
                               Foreground="White"
                               FontWeight="SemiBold"/>
                        <ComboBox Name="Loading_file"
                              Width="200"
                              Height="35"
                              SelectionChanged="FilterGames">
                            <ComboBoxItem IsSelected="True" IsEnabled="False">Выберите вариант...</ComboBoxItem>
                            <ComboBoxItem>XML</ComboBoxItem>
                            <ComboBoxItem>JSON</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- Выбор игры -->
        <Border Grid.Row="1"
            Background="#1E293B"
            CornerRadius="15"
            Margin="20,0">

            <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <TextBlock Text="🎯 Выберите игру:"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="10"
                       VerticalAlignment="Center"/>

                <ComboBox Name="PlatformCombox"
                      Width="420"
                      Height="50"
                      DisplayMemberPath="Title"
                      Margin="20"
                      SelectionChanged="ChoiseGame" />

                <Button x:Name="ButtonImage"
                    Content="Показать данные"
                    Width="220"
                    Height="55"
                    Click="InformationButton"/>
            </StackPanel>

        </Border>

        <!-- Статистика -->
        <UniformGrid Grid.Row="2"
                 Columns="4"
                 Margin="20">

            <Border Background="#2563EB"
                CornerRadius="12"
                Margin="8">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Name="TextOver1"
                           Text="Максимум"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,5"/>
                    <TextBlock Name="MaxBlock"
                           Text="—"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#2563EB"
                CornerRadius="12"
                Margin="8">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Name="TextOver2"
                           Text="Минимум"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,5"/>
                    <TextBlock Name="MinBlock"
                           Text="—"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#2563EB"
                CornerRadius="12"
                Margin="8">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Name="TextOver3"
                           Text="Среднее"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,5"/>
                    <TextBlock Name="SrBlock"
                           Text="—"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#2563EB"
                CornerRadius="12"
                Margin="8">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Name="TextOver4"
                           Text="Медиана"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,5"/>
                    <TextBlock Name="MidBlock"
                           Text="—"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </UniformGrid>

      
        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button x:Name="Close"
                Grid.Column="0"
                Content="← Вернуться обратно"
                Width="220"
                Height="60"
                Margin="30"
                HorizontalAlignment="Left"
                Background="#DC2626"
                Foreground="White"
                Click="CloseButton"/>

            <Button x:Name="Genery"
                Grid.Column="1"
                Content="📁 Открыть Каталог (Управление)"
                Width="280"
                Height="60"
                Margin="30"
                HorizontalAlignment="Right"
                Background="#059669"
                Foreground="White"
                Click="ButtonGeneration"/>

        </Grid>

    </Grid>
</Window>
